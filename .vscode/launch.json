{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Vintage Story (Client) + LogicBlocks",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "prepare-debug",
      "program": "${env:APPDATA}/Vintagestory/Vintagestory.exe",
      "args": [
        "--addModPath=${workspaceFolder}/LogicBlocks/bin/Debug/Mods"
      ],
      "cwd": "${env:APPDATA}/Vintagestory",
      "console": "internalConsole",
      "stopAtEntry": false,
      "justMyCode": false,
      "symbolOptions": {
        "searchPaths": [
          "${workspaceFolder}/LogicBlocks/bin/Debug/Mods/mod"
        ],
        "searchMicrosoftSymbolServer": false
      }
    },
    {
      "name": "Vintage Story (Server) + LogicBlocks",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "prepare-debug",
      "program": "${env:APPDATA}/Vintagestory/VintagestoryServer.exe",
      "args": [
        "--addModPath=${workspaceFolder}/LogicBlocks/bin/Debug/Mods"
      ],
      "cwd": "${env:APPDATA}/Vintagestory",
      "console": "internalConsole",
      "stopAtEntry": false,
      "justMyCode": false,
      "symbolOptions": {
        "searchPaths": [
          "${workspaceFolder}/LogicBlocks/bin/Debug/Mods/mod"
        ],
        "searchMicrosoftSymbolServer": false
      }
    },
    {
      "name": "Attach to Vintage Story",
      "type": "coreclr",
      "request": "attach",
      "justMyCode": false,
      "symbolOptions": {
        "searchPaths": [
          "${workspaceFolder}/LogicBlocks/bin/Debug/Mods/mod"
        ]
      }
    }
  ]
}
